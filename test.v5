fn add(a: number, b: number) -> number {
  return a + b;
}

fn multiply(a: number, b: number) -> number {
  return a * b;
}

fn greet(name: string) -> string {
  return `Hello, ${name}!`;
}

fn main() -> void {
  var sum = add(10, 20);
  var prod = multiply(5, 6);
  var msg = greet("FreeLang");
  print("add(10, 20) =", sum);
  print("multiply(5, 6) =", prod);
  print("greet('FreeLang') =", msg);
}
