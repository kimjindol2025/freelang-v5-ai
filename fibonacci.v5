// FreeLang v5 - Fibonacci 프로그램
// 함수형 프로그래밍

fn fib(n: number) -> number {
  if (n <= 1) return n;
  return fib(n - 1) + fib(n - 2);
}

fn factorial(n: number) -> number {
  if (n <= 1) return 1;
  return n * factorial(n - 1);
}

fn isEven(n: number) -> boolean {
  return n % 2 == 0;
}

fn main() -> void {
  var f10 = fib(10);
  var fact5 = factorial(5);
  var even4 = isEven(4);
  print("fib(10) =", f10);
  print("factorial(5) =", fact5);
  print("isEven(4) =", even4);
}
